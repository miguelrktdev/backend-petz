{
  "name": "backend-petz",
  "version": "1.0.0",
  "description": "Backend for petz social media web app",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "commit": "gitmoji -c",
    "dev": "tsx watch ./src/server.ts",
    "build": "tsup src --out-dir dist",
    "start": "node --watch ./dist/server.js",
    "worker:email": "tsx watch ./src/workers/email-worker.ts",
    "workers": "pnpm run worker:email",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [],
  "author": "@migueldev__",
  "license": "ISC",
  "packageManager": "pnpm@10.18.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "prettier": "3.8.1",
    "prisma": "^7.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.9.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    }
  }
}
