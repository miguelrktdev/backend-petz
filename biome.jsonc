{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	// "extends": [
	//   "ultracite/biome/core"
	// ]
	"javascript": {
		"formatter": {
			"indentWidth": 2,
			"lineWidth": 120,
			"semicolons": "asNeeded",
			"quoteStyle": "double"
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	}
}
