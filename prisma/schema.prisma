generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String          @id @default(uuid())
  name              String
  username          String          @unique
  email             String          @unique
  password_hash     String
  bio               String?
  profile_pic       String?
  profile_pic_id    String?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  email_verified_at DateTime?
  Otps              OTP[]
  ResetPasswords    ResetPassword[]

  @@map("users")
}

model OTP {
  id         String    @id @default(uuid())
  user_id    String
  token      String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  User       User      @relation(fields: [user_id], references: [id])

  @@map("otps")
}

model ResetPassword {
  id         String    @id @default(uuid())
  user_id    String
  token      String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  User       User      @relation(fields: [user_id], references: [id])

  @@map("reset_passwords")
}

model Pet {
  id         String     @id @default(uuid())
  name       String
  birthday   DateTime
  breed      String
  weight     Int
  type       String
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  Comments   Comment[]
  Followed   Follow[]   @relation("followed")
  Following  Follow[]   @relation("following")
  Likes      Like[]
  PetColors  PetColor[]
  Posts      Post[]

  @@map("pets")
}

model PetColor {
  id     String @id @default(uuid())
  pet_id String
  color  String
  Pet    Pet    @relation(fields: [pet_id], references: [id])

  @@map("pet_colors")
}

model Follow {
  followed_id  String
  following_id String
  followed     Pet    @relation("followed", fields: [followed_id], references: [id])
  following    Pet    @relation("following", fields: [following_id], references: [id])

  @@id([followed_id, following_id])
  @@unique([followed_id, following_id])
  @@map("follows")
}

model Post {
  id         String      @id @default(uuid())
  pet_id     String
  caption    String
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  Comments   Comment[]
  Likes      Like[]
  PostImages PostImage[]
  Pet        Pet         @relation(fields: [pet_id], references: [id])

  @@map("posts")
}

model PostImage {
  id      String @id @default(uuid())
  post_id String
  url     String
  Post    Post   @relation(fields: [post_id], references: [id])

  @@map("post_images")
}

model Like {
  id      String @id @default(uuid())
  pet_id  String
  post_id String
  Pet     Pet    @relation(fields: [pet_id], references: [id])
  Post    Post   @relation(fields: [post_id], references: [id])

  @@unique([pet_id, post_id])
  @@map("likes")
}

model Comment {
  id      String @id @default(uuid())
  content String
  pet_id  String
  post_id String
  Pet     Pet    @relation(fields: [pet_id], references: [id])
  Post    Post   @relation(fields: [post_id], references: [id])

  @@map("comments")
}
